{
  "$schema": "https://raw.githubusercontent.com/nickkadams/tauri-docs/refs/heads/dev/docs/.vitepress/public/schema.json",
  "productName": "Sentinella",
  "version": "0.1.0",
  "identifier": "dev.sentinella.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Sentinella Runtime Sensor",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "Copyright © 2026 Sentinella Contributors",
    "license": "MIT",
    "licenseFile": "../../../LICENSE",
    "publisher": "Frenesy",
    "shortDescription": "Real-time Linux kernel threat telemetry EDR application",
    "longDescription": "Sentinella is a kernel-native endpoint detection and response dashboard mapping syscall activities to MITRE ATT&CK via eBPF tracepoints."
  }
}
